{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/favicon.svg",
          "/icon-96.png",
          "/icon-192.png",
          "/icon-512.png",
          "/icon-512-maskable.png",
          "/icon-180-apple.png",
          "/icon-192.svg",
          "/icon-512.svg",
          "/index.html",
          "/*.css",
          "/*.js",
          "/*.webmanifest"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "weather-api",
      "urls": ["https://api.open-meteo.com/v1/forecast"],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 15,
        "maxAge": "7d",
        "timeout": "10s"
      }
    }
  ]
}
